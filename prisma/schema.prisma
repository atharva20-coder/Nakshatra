// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  AGENCY
  AUDITOR
  COLLECTION_MANAGER
  AXIS_EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id          String     @id @default(cuid())
  bankId      String     @unique // Bank-generated ID
  email       String     @unique
  password    String
  role        UserRole
  status      UserStatus @default(PENDING)
  isFirstTime Boolean    @default(true)
  
  // Common fields
  phoneNumber String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Profile relationships
  agencyProfile          AgencyProfile?
  auditorProfile         AuditorProfile?
  collectionManagerProfile CollectionManagerProfile?
  axisEmployeeProfile    AxisEmployeeProfile?
  
  @@map("users")
}

model AgencyProfile {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agencyName        String
  registrationNumber String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  contactPerson     String?
  businessType      String?
  panNumber         String?
  gstNumber         String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("agency_profiles")
}

model AuditorProfile {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  auditorName       String
  firmName          String?
  licenseNumber     String?
  qualification     String?
  experience        Int? // years of experience
  specialization    String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  panNumber         String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("auditor_profiles")
}

model CollectionManagerProfile {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  managerName       String
  employeeId        String?
  department        String?
  designation       String?
  reportingManager  String?
  region            String?
  territory         String?
  experience        Int? // years of experience
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("collection_manager_profiles")
}

model AxisEmployeeProfile {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  employeeName      String
  employeeId        String
  department        String
  designation       String
  branch            String?
  reportingManager  String?
  grade             String?
  zone              String?
  region            String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("axis_employee_profiles")
}

